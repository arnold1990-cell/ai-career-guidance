# Backend Gemini settings (Spring Boot reads these through application.yml placeholders)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional frontend override for API requests.
# In development, leave unset to use Vite proxy (/api -> http://localhost:8080).
# For deployed environments, set this to your backend API base path.
# Example: https://api.example.com/api/v1
VITE_API_BASE_URL=

# Optional: enable seeded guidance demo mode.
# Keep false in production to enforce live Gemini guidance.
VITE_AI_GUIDANCE_DEMO_MODE=false
